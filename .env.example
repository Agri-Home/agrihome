APP_NAME=AgriHome Vision Console
NEXT_PUBLIC_APP_NAME=AgriHome Vision Console
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AUTO_REFRESH_MS=15000
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=agrihome
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=agrihome
# npm run db:seed — db/schema.sql, db/migrations/*.sql, db/seed.sql
# npm run db:migrate — db/migrations/*.sql only (upgrade existing DB)
# npm run db:schema — db/schema.sql only

# Leaf images on disk (not in Postgres). Same layout locally and in Docker.
# Local: omit STORAGE_* → ./storage/originals|processed|temp (created on upload).
# Served at GET /api/files/originals|processed|temp/...
# STORAGE_ROOT=
# STORAGE_ORIGINALS_DIR=
# STORAGE_PROCESSED_DIR=
# STORAGE_TEMP_DIR=

QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agrihome-image-embeddings

# Optional: tray photo → plant count + boxes (see docs/CV_PIPELINE.md)
# CV_TRAY_INFERENCE_URL=https://your-inference.example.com/v1/tray
# CV_TRAY_INFERENCE_API_KEY=

# Required for species / disease from leaf photos (PlantVillage-trained cv-backend)
# https://github.com/spMohanty/PlantVillage-Dataset/tree/master/raw/color
# Full URL including path (app POSTs to this string as-is). Inside Docker the server listens on 8765;
# if Compose maps "8754:8765", use http://<host>:8754/v1/classify from the machine running Next.js.
CV_SPECIES_INFERENCE_URL=http://127.0.0.1:8765/v1/classify
CV_SPECIES_INFERENCE_API_KEY=

# Firebase config (for Auth and Storage; no Realtime Database or Firestore used)
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin credentials for server-side session cookies and protected routes.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON or the split fields below.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project",...}
# FIREBASE_SESSION_COOKIE_NAME=agrihome_session

# --- Feedback ingestion (ML loop) ---
# POST /api/feedback/ingest — multipart field "image" + category/tags/comment.
# FEEDBACK_MAX_IMAGE_BYTES=8388608
# FEEDBACK_INGEST_MAX_PER_USER_PER_MIN=20
# FEEDBACK_INGEST_MAX_PER_IP_PER_MIN=60
# Optional: trusted backends send header X-Agrihome-Feedback-Key + form userUid, userEmail.
# FEEDBACK_INGEST_SERVICE_KEY=
# Optional: mirror each image into an ImageFolder tree (cv-backend/train.py --data-dir layout:
# one folder per class like Tomato___Early_blight, same as PlantVillage raw/color — not raw/).
# PLANTVILLAGE_FEEDBACK_DATASET_DIR=
# Map UI label strings to folder names: {"My dropdown label":"Tomato___Early_blight"}
# PLANTVILLAGE_FEEDBACK_FOLDER_MAP=

# ML export / retrain gate (scripts/ml/*.cjs)
# ML_STAGING_DIR=./storage/ml-staging
# PUBLIC_API_BASE_URL=http://localhost:3000
# ML_LABEL_MAP_JSON={"early blight":"early_blight","powdery mildew":"powdery_mildew"}
# RETRAIN_FEEDBACK_THRESHOLD=1000
# RETRAIN_WEBHOOK_URL=https://your-ci.example/hooks/retrain
# ML_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
