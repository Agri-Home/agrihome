# AgriHome AI stack example environment
# Copy to .env.ai on the server and replace values as needed.
# Do not commit real .env.ai files.

AGRIHOME_CV_BACKEND=./cv-backend
CLASSIFIER_HOST_PORT=8765
CLASSIFIER_PORT=8765
MODEL_PATH=/workspace/artifacts/best.pt
CLASSES_PATH=/workspace/artifacts/classes.json

DATASET_PLANTVILLAGE=/data/plantvillage
DATASET_PLANTDOC=/data/plantdoc
DATASET_PLANT_LEAF=/data/plant-leaf

NVIDIA_VISIBLE_DEVICES=0
NVIDIA_DRIVER_CAPABILITIES=compute,utility
CUDA_VISIBLE_DEVICES=0
USE_CLAHE=0
